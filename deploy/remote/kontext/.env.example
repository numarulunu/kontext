# Remote Kontext deploy package — version 1.0.0
# Copy to .env before deployment.

# Image tags — bump after publishing a new build.
KONTEXT_IMAGE=ghcr.io/ionutrosu/kontext:latest
CADDY_IMAGE=caddy:2.9-alpine

# Public domain for the control plane (used by Caddy for auto-TLS).
KONTEXT_DOMAIN=kontext.ionutrosu.xyz
ACME_EMAIL=ionut@ionutrosu.com

# Internal port inside the kontext container (Caddy forwards 443 -> here).
KONTEXT_PORT=8080

# Background scheduler — how often dream and digest run.
# 0 disables that loop entirely.
DREAM_INTERVAL_HOURS=24
DIGEST_INTERVAL_HOURS=6
DREAM_DRY_RUN=0
WORKER_STARTUP_DELAY_SEC=30
